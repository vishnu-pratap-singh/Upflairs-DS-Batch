"""
Question 4.
create a numpy RY THE DATASET below 
marks: 45, 56, 67, 78, 89

find mean, median, stndard deviation, maximum and minimum



"""

marks = np.array([45,56,67,78,89])
print(f'mean: {np.mean(marks)}')
print(f'medium: {np.median(marks)}')
print(f'standard deviation: {round(np.std(marks),2)}')
print(f'maximum: {np.max(marks)} and \n minimum marks: {np.min(marks)}')

