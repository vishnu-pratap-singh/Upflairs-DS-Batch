"""
Question 5:
Using the array below [10,20,30,40,50,60,70,80]
print first 4 elements
print alternate elements 
reverse the array
replace all elements grater than 50 and 0

Expected concept 
Indexing, slicing, Boolean Masking 
"""

arr=np.array([10,20,30,40,50,60,70,80])
print(f'first 4 element: {arr[:4]}')

print(f'alternate element: {arr[::2]}')

print(f'reverse of array: {arr[::-1]}')

print(f'replace all item greter than 50 with  0')

mask=arr>50
arr[mask]=0
print(f'modified array is: \n{arr}')
